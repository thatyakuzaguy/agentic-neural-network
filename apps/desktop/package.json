{
  "name": "@aen/desktop",
  "private": true,
  "version": "0.1.5",
  "description": "Desktop shell for ANN (Agentic Neural Network)",
  "main": "src/main.js",
  "author": "ANN contributors",
  "license": "MIT",
  "scripts": {
    "dev": "electron .",
    "package": "electron-packager . \"ANN\" --platform=win32 --arch=x64 --electron-version=42.3.3 --out=dist --overwrite --asar --ignore=\"^dist($|/)\"",
    "package:portable": "electron-builder --win portable --x64"
  },
  "dependencies": {},
  "devDependencies": {
    "@electron/packager": "19.0.1",
    "electron": "42.3.3",
    "electron-builder": "26.8.1"
  },
  "build": {
    "appId": "local.agentic-engineering-network.desktop",
    "productName": "ANN",
    "electronVersion": "42.3.3",
    "asar": true,
    "directories": {
      "output": "dist"
    },
    "files": [
      "src/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ]
    }
  }
}
